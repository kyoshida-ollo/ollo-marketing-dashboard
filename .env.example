# このファイルを .env にコピーして値を設定する（.env はgitignore済み）

# 施策集計スプレッドシート（LookerStudio_data）。省略時はデフォルトのIDを使用
DASHBOARD_SHEET_ID=1kaNNLhxanVi8LwvlWvMYKArBlV3H19dMHAsS8xPhuUk
DASHBOARD_SHEET_TAB=expense_lead

# Google Cloudサービスアカウントの鍵ファイル（secrets/ に置く）
# シートの共有設定にサービスアカウントのメールアドレスを閲覧者として追加すること
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/service-account.json

